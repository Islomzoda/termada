{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.Islomzoda/termada",
  "description": "Reliable, transparent terminal runtime between AI agents and the shell (local + SSH).",
  "repository": {
    "url": "https://github.com/Islomzoda/termada",
    "source": "github"
  },
  "version": "0.8.0",
  "packages": [
    {
      "registryType": "oci",
      "identifier": "ghcr.io/islomzoda/termada:0.8.0",
      "transport": { "type": "stdio" },
      "packageArguments": [
        { "type": "positional", "value": "serve" },
        { "type": "positional", "value": "--stdio" }
      ]
    }
  ]
}
